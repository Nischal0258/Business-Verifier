# =============================================================================
# GEMINI API KEY (REQUIRED)
# =============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
# This key is required for company verification and LLM analysis.
GEMINI_API_KEY=your_gemini_key_here

# =============================================================================
# SERPER API KEY (RECOMMENDED)
# =============================================================================
# Get your API key from: https://serper.dev/
# This key is highly recommended for searching Indian and private companies.
SERPER_API_KEY=your_serper_key_here

# =============================================================================
# CORS ORIGINS (Optional)
# =============================================================================
# Comma-separated list of allowed origins for cross-origin requests.
# Default allows Next.js dev server on localhost:3000.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# DATABASE URL (Optional)
# =============================================================================
# SQLite is used by default for development.
DATABASE_URL=sqlite+aiosqlite:///./business_verify.db
